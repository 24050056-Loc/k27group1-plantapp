{
  "expo": {
    "name": "Modern Mobile Marketplace App",
    "slug": "modern-mobile-marketplace-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Tree.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/Tree.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Tree.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/Tree.png"
    },
    "extra": {
      "router": {
        "root": "app"
      }
    }
  }
}

{
  "expo": {
    "name": "Modern Mobile Marketplace App",
    "slug": "modern-mobile-marketplace-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Tree.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/Tree.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ứng dụng cần quyền truy cập thư viện ảnh để đổi ảnh đại diện.",
          "cameraPermission": "Ứng dụng cần quyền dùng camera để chụp ảnh đại diện."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/Tree.png",
          "color": "#2E7D32",
          "defaultChannel": "plant-care",
          "androidMode": "default",
          "androidCollapsedTitle": "PlantApp 🌿"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Tree.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/Tree.png"
    },
    "extra": {
      "router": {
        "root": "app"
      }
    }
  }
}